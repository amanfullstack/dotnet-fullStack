@model ProductCatalogMVC.Models.Product

@{
    ViewData["Title"] = $"Delete {Model.Name}";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">⚠️ Delete Confirmation</h4>
            <p>Are you sure you want to delete this product?</p>
            <hr>
            <p class="mb-0">
                <strong>Product:</strong> @Model.Name<br>
                <strong>Price:</strong> $@Model.Price:F2<br>
                <strong>Category:</strong> @Model.Category
            </p>
        </div>

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    🗑️ Yes, Delete This Product
                </button>
                <a href="/Products/Details/@Model.Id" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
