@model List<ProductCatalogMVC.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h1 class="mb-0">📦 Products</h1>
        <p class="text-muted">Browse and manage your product catalog</p>
    </div>
    <div class="col-md-4 text-end">
        <a href="/Products/Create" class="btn btn-primary">
            <i class="bi bi-plus"></i> Add New Product
        </a>
    </div>
</div>

<!-- Search & Filter -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2">
            <div class="col-md-6">
                <input type="text" class="form-control" placeholder="Search by name..." name="searchTerm" value="@ViewBag.SearchTerm">
            </div>
            <div class="col-md-4">
                <select class="form-select" name="categoryFilter">
                    <option value="">All Categories</option>
                    @foreach (var category in ViewBag.Categories)
                    {
                        <option value="@category" selected="@(category == ViewBag.CategoryFilter)">@category</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-secondary w-100">🔍 Search</button>
            </div>
        </form>
    </div>
</div>

<!-- Products Table -->
@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td class="fw-bold">@product.Name</td>
                        <td><span class="badge bg-info">@product.Category</span></td>
                        <td>${@product.Price:F2}</td>
                        <td>
                            <span class="badge @(product.StockQuantity > 10 ? "bg-success" : product.StockQuantity > 0 ? "bg-warning" : "bg-danger")">
                                @product.StockQuantity
                            </span>
                        </td>
                        <td>@product.CreatedDate.ToString("MMM dd, yyyy")</td>
                        <td class="text-end">
                            <a href="/Products/Details/@product.Id" class="btn btn-sm btn-info">View</a>
                            <a href="/Products/Edit/@product.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a href="/Products/Delete/@product.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info text-center py-5">
        <h5>No products found</h5>
        <p class="mb-0">Try adjusting your search filters or create a new product.</p>
    </div>
}

<style>
    .btn-sm { padding: 0.35rem 0.65rem; font-size: 0.85rem; }
    .table { margin-bottom: 0; }
</style>
